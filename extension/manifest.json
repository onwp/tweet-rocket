{
  "manifest_version": 3,
  "name": "TweetRocket",
  "version": "1.0.0",
  "description": "Write viral tweets powered by X's algorithm — score, optimize, and generate tweets that maximize reach.",
  "permissions": ["storage", "sidePanel"],
  "action": {
    "default_popup": "app.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "app.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
